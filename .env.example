# ─── Mesh Storage (dedicated instances — isolated from system memory) ─────────
MESH_REDIS_REST_URL=https://your-mesh-redis.upstash.io
MESH_REDIS_REST_TOKEN=
MESH_VECTOR_REST_URL=https://your-mesh-vector.upstash.io
MESH_VECTOR_REST_TOKEN=
MESH_SEARCH_REST_URL=https://your-mesh-search.upstash.io
MESH_SEARCH_REST_TOKEN=

# ─── Upstash QStash ───────────────────────────────────────────────────────────
QSTASH_TOKEN=
QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Upstash Box ──────────────────────────────────────────────────────────────
UPSTASH_BOX_API_KEY=

# ─── Ably ─────────────────────────────────────────────────────────────────────
ABLY_API_KEY=

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Upstash Developer API (for provisioning new instances) ──────────────────
UPSTASH_DEVELOPER_API_KEY=
UPSTASH_ACCOUNT_EMAIL=

# ─── Workflow server public URL (must be reachable by QStash) ─────────────────
WORKFLOW_URL=https://your-server.example.com
